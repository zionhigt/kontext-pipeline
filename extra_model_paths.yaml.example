# Exemple : modeles FLUX.1 Kontext stockes hors du repo (autre disque).
#
# Utilisation :
#   1. Copier ce fichier en `extra_model_paths.yaml` a la racine du projet
#      (cote du README, PAS dans ComfyUI\). Le .gitignore l'ignore deja.
#   2. Adapter `base_path` au chemin reel sur votre disque.
#   3. Lancer `scripts\start_comfy.bat` : il detecte le fichier et l'injecte
#      dans ComfyUI via --extra-model-paths-config.
#
# Structure attendue sous base_path :
#   D:\IA\models\
#     diffusion_models\flux1-kontext-dev-fp8-scaled.safetensors
#     text_encoders\clip_l.safetensors
#     text_encoders\t5xxl_fp8_e4m3fn.safetensors
#     vae\ae.safetensors
#
# ComfyUI fusionne ces dossiers avec ses `models/` natifs ; vous n'avez pas
# besoin de tout deplacer, seulement ce qui est gros (les .safetensors).

kontext_external:
  base_path: D:/IA/models
  diffusion_models: diffusion_models/
  text_encoders: text_encoders/
  vae: vae/
  checkpoints: checkpoints/
  loras: loras/
  clip: text_encoders/
  unet: diffusion_models/
